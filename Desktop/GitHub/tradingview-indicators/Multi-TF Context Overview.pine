
//@version=6
indicator("Multi-TF Context Overview", overlay = true, max_boxes_count = 500, max_lines_count = 500, max_labels_count = 500)

// ─────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────

// Weekly
showWeekly      = input.bool(true,  "Show Weekly Structure")
weeklyColor     = input.color(color.yellow, "Weekly Outline Color")

// Daily
showDailyLevels = input.bool(true,  "Show Daily High/Low")
dailyColor      = input.color(color.new(color.blue, 0), "Daily HL Color")

// Inside Day
showInside      = input.bool(true,  "Highlight Inside Days")
insideColor     = input.color(color.new(color.gray, 85), "Inside Day Color")

// Previous Day Open
showPDOpen      = input.bool(true,  "Show Previous Day Open")
pdOpenColor     = input.color(color.new(color.blue, 0), "PD Open Color")

// ─────────────────────────────────────────────
// TIMEFRAME CONDITIONS
// ─────────────────────────────────────────────

showWeeklyTF = timeframe.in_seconds() < timeframe.in_seconds("W")
showDailyTF  = timeframe.in_seconds() < timeframe.in_seconds("D")

// ─────────────────────────────────────────────
// WEEKLY DATA
// ─────────────────────────────────────────────

wOpen  = request.security(syminfo.tickerid, "W", open,  lookahead = barmerge.lookahead_off)
wHigh  = request.security(syminfo.tickerid, "W", high,  lookahead = barmerge.lookahead_off)
wLow   = request.security(syminfo.tickerid, "W", low,   lookahead = barmerge.lookahead_off)
wClose = request.security(syminfo.tickerid, "W", close, lookahead = barmerge.lookahead_off)

newWeek = ta.change(time("W")) != 0

var box weeklyBox = na
var line weeklyHighLine = na
var line weeklyLowLine  = na

if showWeekly and showWeeklyTF
    if newWeek
        weeklyBox := box.new(
             left = bar_index,
             right = bar_index,
             top = math.max(wOpen, wClose),
             bottom = math.min(wOpen, wClose),
             border_color = weeklyColor,
             bgcolor = na)

        weeklyHighLine := line.new(bar_index, wHigh, bar_index, wHigh, color = weeklyColor)
        weeklyLowLine  := line.new(bar_index, wLow,  bar_index, wLow,  color = weeklyColor)

    if not na(weeklyBox)
        box.set_right(weeklyBox, bar_index)
        box.set_top(weeklyBox, math.max(wOpen, wClose))
        box.set_bottom(weeklyBox, math.min(wOpen, wClose))

    if not na(weeklyHighLine)
        line.set_x2(weeklyHighLine, bar_index)
        line.set_y1(weeklyHighLine, wHigh)
        line.set_y2(weeklyHighLine, wHigh)

    if not na(weeklyLowLine)
        line.set_x2(weeklyLowLine, bar_index)
        line.set_y1(weeklyLowLine, wLow)
        line.set_y2(weeklyLowLine, wLow)

// ─────────────────────────────────────────────
// DAILY DATA
// ─────────────────────────────────────────────

dHigh  = request.security(syminfo.tickerid, "D", high, lookahead = barmerge.lookahead_off)
dLow   = request.security(syminfo.tickerid, "D", low,  lookahead = barmerge.lookahead_off)
dOpen  = request.security(syminfo.tickerid, "D", open, lookahead = barmerge.lookahead_off)

prevHigh = dHigh[1]
prevLow  = dLow[1]
prevOpen = dOpen[1]

newDay = ta.change(time("D")) != 0

var line dayHighLine = na
var line dayLowLine  = na
var line pdOpenLine  = na
var label pdLabel    = na
var box insideBox    = na

// Daily High/Low
if showDailyLevels and showDailyTF
    if newDay
        dayHighLine := line.new(bar_index, prevHigh, bar_index, prevHigh, color = dailyColor, width = 2)
        dayLowLine  := line.new(bar_index, prevLow,  bar_index, prevLow,  color = dailyColor, width = 2)

    if not na(dayHighLine)
        line.set_x2(dayHighLine, bar_index)

    if not na(dayLowLine)
        line.set_x2(dayLowLine, bar_index)

// ─────────────────────────────────────────────
// INSIDE DAY
// ─────────────────────────────────────────────

insideDay = (prevHigh < dHigh[2]) and (prevLow > dLow[2])

if showInside and showDailyTF
    if newDay and insideDay
        insideBox := box.new(
            left = bar_index,
            right = bar_index,
            top = prevHigh,
            bottom = prevLow,
            bgcolor = insideColor,
            border_color = na)

    if not na(insideBox)
        box.set_right(insideBox, bar_index)

// ─────────────────────────────────────────────
// PREVIOUS DAY OPEN
// ─────────────────────────────────────────────

if showPDOpen and showDailyTF
    if newDay
        pdOpenLine := line.new(bar_index, prevOpen, bar_index, prevOpen, color = pdOpenColor, width = 2)

        pdLabel := label.new(
            bar_index,
            prevOpen,
            "pd.open",
            style = label.style_label_right,
            textcolor = pdOpenColor,
            color = color.new(color.black, 100),
            size = size.small)

    if not na(pdOpenLine)
        line.set_x2(pdOpenLine, bar_index)

    if not na(pdLabel)
        label.set_x(pdLabel, bar_index)
        label.set_y(pdLabel, prevOpen)